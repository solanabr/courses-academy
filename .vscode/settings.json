{
  "yaml.schemas": {
    "./schema/course.schema.json": ["courses/*/course.yaml"],
    "./schema/lesson.schema.json": ["courses/*/lessons/*/lesson.yaml"],
    "./schema/quiz.schema.json": ["courses/*/lessons/*/*.quiz.yaml"],
    "./schema/achievement.schema.json": ["achievements/*.yaml"],
    "./schema/quest.schema.json": ["quests/*.yaml"],
    "./schema/path.schema.json": ["paths/*.yaml"]
  },
  "json.schemas": [
    {
      "fileMatch": ["courses/*/slots.lock.json"],
      "url": "./schema/slots.schema.json"
    }
  ],
  "files.associations": {
    "*.quiz.yaml": "yaml"
  }
}
