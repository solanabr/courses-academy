    "expectedOutput": "__result__[4] == b'A'"
  },
  {
    "id": "t4",
    "description": "Correct layout for a different input (len prefix, owner, frozen flag)",
    "input": "\"Sol\", 7, true",
    "expectedOutput": "__result__[0] == 3 && __result__[4] == b'S' && __result__[15] == 1"
  }
