    "expectedOutput": "__result__.len() == 18"
  },
  {
    "id": "t2",
    "description": "Serialized length for a 3-char owner",
    "input": "\"Bob\", 42, true",
    "expectedOutput": "__result__.len() == 16"
  },
  {
    "id": "t3",
    "description": "Owner bytes start at offset 4",
